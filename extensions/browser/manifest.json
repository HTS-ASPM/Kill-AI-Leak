{
  "manifest_version": 3,
  "name": "Kill-AI-Leak",
  "version": "1.0.0",
  "description": "Monitor AI usage, detect shadow AI, and prevent data leaks in real time.",
  "permissions": [
    "webRequest",
    "storage",
    "identity",
    "tabs",
    "activeTab",
    "alarms",
    "notifications"
  ],
  "host_permissions": [
    "https://chat.openai.com/*",
    "https://chatgpt.com/*",
    "https://api.openai.com/*",
    "https://claude.ai/*",
    "https://api.anthropic.com/*",
    "https://gemini.google.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://aistudio.google.com/*",
    "https://copilot.microsoft.com/*",
    "https://www.bing.com/chat/*",
    "https://poe.com/*",
    "https://perplexity.ai/*",
    "https://www.perplexity.ai/*",
    "https://huggingface.co/*",
    "https://api-inference.huggingface.co/*",
    "https://bard.google.com/*",
    "https://you.com/*",
    "https://character.ai/*",
    "https://beta.character.ai/*",
    "https://pi.ai/*",
    "https://inflection.ai/*",
    "https://coral.cohere.com/*",
    "https://api.cohere.ai/*",
    "https://chat.mistral.ai/*",
    "https://api.mistral.ai/*",
    "https://labs.perplexity.ai/*",
    "https://groq.com/*",
    "https://api.groq.com/*",
    "https://together.ai/*",
    "https://api.together.xyz/*",
    "https://fireworks.ai/*",
    "https://api.fireworks.ai/*",
    "https://deepseek.com/*",
    "https://api.deepseek.com/*",
    "https://github.com/copilot/*",
    "https://copilot.github.com/*",
    "https://cursor.sh/*",
    "https://www.cursor.sh/*",
    "https://replit.com/*",
    "https://codeium.com/*",
    "https://tabnine.com/*",
    "https://sourcegraph.com/*",
    "https://cody.dev/*",
    "https://midjourney.com/*",
    "https://www.midjourney.com/*",
    "https://discord.com/channels/*",
    "https://stability.ai/*",
    "https://api.stability.ai/*",
    "https://dream.ai/*",
    "https://app.leonardo.ai/*",
    "https://www.imagine.art/*",
    "https://ideogram.ai/*",
    "https://designer.microsoft.com/*",
    "https://runwayml.com/*",
    "https://app.runwayml.com/*",
    "https://elevenlabs.io/*",
    "https://api.elevenlabs.io/*",
    "https://play.ht/*",
    "https://murf.ai/*",
    "https://www.descript.com/*",
    "https://suno.com/*",
    "https://www.jasper.ai/*",
    "https://writesonic.com/*",
    "https://www.copy.ai/*",
    "https://rytr.me/*",
    "https://notebooklm.google.com/*",
    "https://openrouter.ai/*",
    "https://api.openrouter.ai/*",
    "https://replicate.com/*",
    "https://api.replicate.com/*",
    "https://app.wordtune.com/*",
    "https://app.grammarly.com/*",
    "https://ollama.com/*"
  ],
  "background": {
    "service_worker": "dist/background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chat.openai.com/*",
        "https://chatgpt.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://aistudio.google.com/*",
        "https://copilot.microsoft.com/*",
        "https://www.bing.com/chat/*",
        "https://poe.com/*",
        "https://perplexity.ai/*",
        "https://www.perplexity.ai/*",
        "https://character.ai/*",
        "https://beta.character.ai/*",
        "https://pi.ai/*",
        "https://coral.cohere.com/*",
        "https://chat.mistral.ai/*",
        "https://groq.com/*",
        "https://deepseek.com/*",
        "https://you.com/*",
        "https://huggingface.co/chat/*",
        "https://notebooklm.google.com/*"
      ],
      "js": ["dist/content/scanner.js", "dist/content/anonymizer.js"],
      "css": ["dist/content/overlay.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "dist/popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["dist/content/overlay.css"],
      "matches": ["<all_urls>"]
    }
  ]
}
