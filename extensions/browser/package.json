{
  "name": "@kill-ai-leak/browser-extension",
  "version": "1.0.0",
  "private": true,
  "description": "Kill-AI-Leak browser extension - Monitor AI usage, detect shadow AI, prevent data leaks",
  "scripts": {
    "dev": "webpack --watch --mode development",
    "build": "webpack --mode production",
    "build:dev": "webpack --mode development",
    "lint": "eslint src/ --ext .ts,.tsx",
    "lint:fix": "eslint src/ --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "package": "npm run clean && npm run build && cd dist && zip -r ../kill-ai-leak-chrome.zip ."
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.33.0",
    "@types/chrome": "^0.0.270",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "copy-webpack-plugin": "^12.0.2",
    "css-loader": "^7.1.0",
    "eslint": "^8.57.0",
    "html-webpack-plugin": "^5.6.0",
    "mini-css-extract-plugin": "^2.9.0",
    "ts-loader": "^9.5.1",
    "typescript": "^5.5.0",
    "webpack": "^5.93.0",
    "webpack-cli": "^5.1.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
